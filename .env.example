# Copy to .env and customise. Variables flow into docker compose, which forwards
# them to the backend container.

# Local model server — LM Studio running on your Mac (the desktop GUI app).
# Start LM Studio, load your model, click "Start Server" (default port 1234),
# and the backend container reaches it via host.docker.internal.
PARSLI_MODEL__PROVIDER=lmstudio
PARSLI_MODEL__ENDPOINT_URL=http://host.docker.internal:1234
PARSLI_MODEL__MODEL_NAME=google/gemma-4-e4b
PARSLI_MODEL__TIMEOUT_SECONDS=120

# How many days of email history to ingest on a new account's first sync.
PARSLI_GMAIL__LOOKBACK_DAYS=60

# Optional: override where credentials.json / tokens / parsli.db live on the
# host. Defaults to ./backend/.parsli relative to docker-compose.yml.
# PARSLI_DATA_DIR=/absolute/path/to/parsli-data
